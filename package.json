{
  "name": "vitepress-project",
  "private": true,
  "type": "module",
  "scripts": {
    "pre:version": "node ./scripts/fetch-butler-sos-version.mjs",
    "pre:latest": "node ./scripts/copy-latest-docs.mjs",
    "dev": "npm run pre:version && npm run pre:latest && vitepress dev docs",
    "build": "npm run pre:version && npm run pre:latest && vitepress build docs",
    "serve": "npm run pre:version && npm run pre:latest && vitepress serve docs",
    "deploy": "gh workflow run deploy-vitepress.yml --ref $(git branch --show-current)"
  },
  "devDependencies": {
    "mermaid": "^11.15.0",
    "ufo": "^1.6.4",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vue": "^3.5.34"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@algolia/client-search"
      ]
    }
  },
  "dependencies": {
    "medium-zoom": "^1.1.0",
    "vitepress-openapi": "^0.2.0"
  }
}
